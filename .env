DB_URL=sqlite:///./rasp.db
REDIS_URL=redis://localhost:6379
LOG_SECRET_KEY=demo-secret-key-12345
SAFE_MODE=false

# Rate Limiting Configuration
RATE_LIMITING_ENABLED=true
RATE_LIMIT_STRATEGY=token_bucket
# Options: token_bucket, sliding_window, fixed_window, adaptive
RATE_LIMIT_DEFAULT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=1
BLOCK_ON_RATE_LIMIT=true
RATE_LIMIT_BLOCK_DURATION=300
TRACK_RATE_LIMIT_VIOLATIONS=true
